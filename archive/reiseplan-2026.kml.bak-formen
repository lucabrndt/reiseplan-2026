  <Folder>
    <name>Schweiz (Rot)</name>
    <Placemark>
      <name>Grossmünster ⭐</name>
      <description>Wahrzeichen Zürichs · Turmbesteigung 5 CHF | Zwinglipl. 7, 8001 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.544054,47.3700931,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Fraumünster ⭐⭐</name>
      <description>Chagall-Fenster · ~5 CHF · Mo–Sa 10–18 Uhr | Münsterhof 2, 8001 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5408331,47.3697849,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>St. Peterskirche</name>
      <description>Größtes Kirchturm-Zifferblatt Europas · Gratis | St. Peterhofstatt 1, 8001 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5407181,47.3711462,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Lindenhof</name>
      <description>Aussichtshügel · Schach · Gratis | Lindenhof, 8001 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5413182,47.3721811,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>ETH Polyterrasse</name>
      <description>Panoramablick Stadt + Alpen · Gratis | Polyterrasse ETH, 8001 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5463439,47.3768403,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Museum für Gestaltung ⭐⭐</name>
      <description>12–15 CHF · Di–So (Mo geschlossen!) | Ausstellungsstrasse 60, 8005 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5358278,47.3827672,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Freitag Tower ⭐</name>
      <description>Flagship Store + Aussicht · Gratis | Geroldstrasse 21, 8005 Zürich, Switzerland | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.5193857,47.3856597,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Flussbad Oberer Letten ⭐</name>
      <description>Schwimmen im Limmat · Gratis | Lettensteg 10, 8037 Zürich, Switzerland | Kategorie: Natur &amp; Aktivität | Stadt: Zürich</description>
      <styleUrl>#CH-nature</styleUrl>
      <Point><coordinates>8.5345306,47.3856866,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Wochenmarkt Bürkliplatz ⭐</name>
      <description>Di + Fr 6–11 Uhr · Gratis | Fraumünsterstrasse, 8001 Zürich, Switzerland | Kategorie: Markt / Shopping / Sonstiges | Stadt: Zürich</description>
      <styleUrl>#CH-market</styleUrl>
      <Point><coordinates>8.5407526,47.3693507,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Uetliberg ⭐</name>
      <description>871 m Aussicht · S10 25 Min ab HB | Uetliberg, 8143 Stallikon, Switzerland | Kategorie: Natur &amp; Aktivität | Stadt: Zürich</description>
      <styleUrl>#CH-nature</styleUrl>
      <Point><coordinates>8.49205,47.3495,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Altstadt / Niederdorf</name>
      <description>Das historische Herz Zürichs auf beiden Seiten der Limmat. Kopfsteinpflaster, bunte Fassaden, kleine Gassen, Cafés auf Holzstühlen vor der Tür. Einfach durchschlendern. | Niederdorf, 8001 Zürich, Schweiz | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.544643,47.374899,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Zürichsee</name>
      <description>Spazieren, Sitzen, Schauen. Schiffsfahrten auf dem See ebenfalls möglich. | Zürich, Schweiz | Kategorie: Natur &amp; Aktivität | Stadt: Zürich</description>
      <styleUrl>#CH-nature</styleUrl>
      <Point><coordinates>8.541694,47.376887,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Botanischer Garten</name>
      <description>7.000 Pflanzenarten aus aller Welt, darunter tropische Glashäuser. Schön für eine ruhige Stunde. | Zollikerstrasse 107, 8008 Zürich, Switzerland | Kategorie: Natur &amp; Aktivität | Stadt: Zürich</description>
      <styleUrl>#CH-nature</styleUrl>
      <Point><coordinates>8.561606,47.358005,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Sukkulenten-Sammlung</name>
      <description>Eine der größten der Welt in mehreren Glashäusern. Riesige Kakteen, Aloen, kuriose Gewächse. | Mythenquai 88, 8002 Zürich, Switzerland| Kategorie: Natur &amp; Aktivität | Stadt: Zürich</description>
      <styleUrl>#CH-nature</styleUrl>
      <Point><coordinates>8.535094,47.356099,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Kreis 4 &amp; 5 / Langstrasse</name>
      <description>Zürichs Kreativviertel. Ehemalige Arbeiterviertel mit Rotlichtgeschichte, jetzt voll mit Ateliers von ZHdK-Absolventen, Galerien, Upcycling-Stores, Designboutiquen. Einfach durchlaufen. | ⚠️ Koordinaten ungefähr – API-Quota erreicht, noch zu verifizieren | Kategorie: Sehenswürdigkeit / Kultur | Stadt: Zürich</description>
      <styleUrl>#CH-sight</styleUrl>
      <Point><coordinates>8.529,47.378,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Markthalle im Viadukt (Kreis 5)</name>
      <description>Alter Eisenbahnviadukt umgebaut zu einer Foodhalle mit angeschlossenen Designshops. Die Bögen des Viadukts beherbergen lokale Händler, Cafés und Spezialitätenläden. Tolles industrielles Flair. | Viaduktstrasse, 8005 Zürich, Schweiz | Kategorie: Markt / Shopping / Sonstiges | Stadt: Zürich</description>
      <styleUrl>#CH-market</styleUrl>
      <Point><coordinates>8.526571,47.387908,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Bratwurst vom Sternen Grill ⭐</name>
      <description>Zürcher Kult seit Jahrzehnten. Am Bellevueplatz. Die weiße Kalbsbratwurst ohne Senf essen — das ist die lokale Regel. | Theaterstrasse 22, 8001 Zürich, Schweiz | Kategorie: Essen &amp; Trinken | Stadt: Zürich</description>
      <styleUrl>#CH-food</styleUrl>
      <Point><coordinates>8.545594,47.367322,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Luxemburgerli bei Sprüngli (Bahnhofstrasse)</name>
      <description>Mini-Macarons von Sprüngli. Teuer aber legendär. Gut als kleiner Snack zwischendurch. | Bahnhofstrasse 21, 8001 Zürich, Schweiz | Kategorie: Essen &amp; Trinken | Stadt: Zürich</description>
      <styleUrl>#CH-food</styleUrl>
      <Point><coordinates>8.539164,47.369515,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Acapulco Bar</name>
      <description>Di–Fr 17–20 Uhr gratis Apérobuffet mit Häppchen. | ⚠️ Koordinaten grob (Stadtzentrum) – API-Quota erreicht, noch zu verifizieren | Kategorie: Essen &amp; Trinken | Stadt: Zürich</description>
      <styleUrl>#CH-food</styleUrl>
      <Point><coordinates>8.53365,47.3727,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>La Tanza</name>
      <description>Sa ab 18 Uhr gratis Tomaten-Pasta (solange Vorrat reicht). | ⚠️ Koordinaten grob (Stadtzentrum) – API-Quota erreicht, noch zu verifizieren | Kategorie: Essen &amp; Trinken | Stadt: Zürich</description>
      <styleUrl>#CH-food</styleUrl>
      <Point><coordinates>8.53365,47.3727,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>sBier Brauerei (Kilchberg)</name>
      <description>Sa Vormittag gratis Bierverkostung. | ⚠️ Koordinaten ungefähr – API-Quota erreicht, noch zu verifizieren | Kategorie: Essen &amp; Trinken | Stadt: Zürich</description>
      <styleUrl>#CH-food</styleUrl>
      <Point><coordinates>8.545,47.324,0</coordinates></Point>
    </Placemark>
  </Folder>
